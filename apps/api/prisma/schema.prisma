// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AIRPORT & AREA
// ============================================

model Airport {
  id              String   @id @default(uuid())
  code            String   @unique           // ADB
  name            String                     // Izmir Adnan Menderes
  countryCode     String   @map("country_code")
  defaultCurrency String   @default("TRY") @map("default_currency")
  timezone        String   @default("Europe/Istanbul")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  areas           Area[]
  tenants         Tenant[]
  contracts       Contract[]
  billingRuns     BillingRun[]
  billingPolicies BillingPolicy[]
  equipment       Equipment[]
  tenantGroups    TenantGroup[]

  @@map("airport")
}

model Area {
  id                 String              @id @default(uuid())
  airportId          String              @map("airport_id")
  parentAreaId       String?             @map("parent_area_id")
  code               String                                    // DOM-G-R-001
  name               String
  areaType           AreaType            @map("area_type")     // terminal, floor, zone, unit
  areaM2             Decimal?            @map("area_m2") @db.Decimal(10, 2)
  heightM            Decimal?            @map("height_m") @db.Decimal(6, 2)
  unitClassification UnitClassification? @map("unit_classification")
  isLeasable         Boolean             @default(false) @map("is_leasable")
  isActive           Boolean             @default(true) @map("is_active")
  // === v2: Area Enhancements ===
  areaCategory       AreaCategory?       @map("area_category")
  usageType          AreaUsageType?      @map("usage_type")
  maxOccupants       Int?                @map("max_occupants")
  isShared           Boolean             @default(false) @map("is_shared")
  baseRatePerM2      Decimal?            @map("base_rate_per_m2") @db.Decimal(10, 2)
  premiumMultiplier  Decimal?            @default(1.0) @map("premium_multiplier") @db.Decimal(5, 2)
  availableFrom      DateTime?           @map("available_from") @db.Date
  availableUntil     DateTime?           @map("available_until") @db.Date
  floorPlanUrl       String?             @map("floor_plan_url")
  // === end v2 ===
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  airport       Airport          @relation(fields: [airportId], references: [id])
  parent        Area?            @relation("AreaHierarchy", fields: [parentAreaId], references: [id])
  children      Area[]           @relation("AreaHierarchy")
  contractAreas ContractArea[]
  equipment     Equipment[]
  occupancies   AreaOccupancy[]
  allocations   AreaAllocation[]
  meters        Meter[]

  @@unique([airportId, code])
  @@index([parentAreaId])
  @@map("area")
}

enum AreaType {
  terminal
  floor
  zone
  unit
}

enum AreaCategory {
  commercial
  operational
  common
  technical
}

enum AreaUsageType {
  retail
  food_and_beverage
  duty_free
  lounge
  advertising
  office
  storage
  parking
  car_rental
  bank_atm
  other
}

enum UnitClassification {
  commercial
  food_beverage
  bank
  rent_a_car
  office
  storage
  lounge
  duty_free
  other
}

enum MeterType {
  electricity
  water
  gas
  heating
}

model Meter {
  id            String    @id @default(uuid())
  areaId        String    @map("area_id")
  serialNumber  String    @map("serial_number")
  meterType     MeterType @map("meter_type")
  location      String?
  isActive      Boolean   @default(true) @map("is_active")
  installedAt   DateTime? @map("installed_at") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  area          Area      @relation(fields: [areaId], references: [id])

  @@unique([areaId, serialNumber])
  @@map("meter")
}


// ============================================
// TENANT
// ============================================

model Tenant {
  id                    String                @id @default(uuid())
  airportId             String                @map("airport_id")
  code                  String                                  // TNT-001
  name                  String
  taxId                 String?               @map("tax_id")
  email                 String?
  phone                 String?
  address               String?
  stripeCustomerId      String?               @map("stripe_customer_id")
  status                TenantStatus          @default(active)
  // === v2: Tenant Enhancements ===
  tenantGroupId         String?               @map("tenant_group_id")
  classification        TenantClassification? @map("classification")
  businessType          String?               @map("business_type")
  brandName             String?               @map("brand_name")
  legalEntityType       LegalEntityType?      @map("legal_entity_type")
  registrationNumber    String?               @map("registration_number")
  annualRevenueEstimate Decimal?              @map("annual_revenue_estimate") @db.Decimal(15, 2)
  employeeCount         Int?                  @map("employee_count")
  contactPerson         String?               @map("contact_person")
  website               String?
  onboardingStatus      OnboardingStatus?     @map("onboarding_status")
  onboardingCompletedAt DateTime?             @map("onboarding_completed_at")
  insurancePolicyNumber String?               @map("insurance_policy_number")
  insuranceExpiry       DateTime?             @map("insurance_expiry") @db.Date
  // === end v2 ===
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  airport           Airport               @relation(fields: [airportId], references: [id])
  tenantGroup       TenantGroup?          @relation(fields: [tenantGroupId], references: [id])
  contracts         Contract[]
  declarations      Declaration[]
  obligations       Obligation[]
  invoiceLogs       InvoiceLog[]
  notifications     Notification[]
  scores            TenantScore[]
  creditNotes       CreditNote[]
  areaOccupancies   AreaOccupancy[]
  allocationShares  AreaAllocationShare[]

  @@unique([airportId, code])
  @@map("tenant")
}

enum TenantStatus {
  active
  suspended
  deactivated
  onboarding
}

enum TenantClassification {
  anchor
  standard
  startup
  temporary
  franchise
}

enum LegalEntityType {
  corporation
  limited_company
  sole_proprietor
  partnership
  cooperative
  branch_office
}

enum OnboardingStatus {
  pending_documents
  documents_received
  under_review
  approved
  completed
}

// ============================================
// TENANT GROUP (Parent-Subsidiary)
// ============================================

model TenantGroup {
  id            String       @id @default(uuid())
  airportId     String       @map("airport_id")
  code          String                        // GRP-001
  name          String
  parentGroupId String?      @map("parent_group_id")
  taxId         String?      @map("tax_id")
  contactEmail  String?      @map("contact_email")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  airport       Airport      @relation(fields: [airportId], references: [id])
  parentGroup   TenantGroup? @relation("TenantGroupHierarchy", fields: [parentGroupId], references: [id])
  childGroups   TenantGroup[] @relation("TenantGroupHierarchy")
  tenants       Tenant[]

  @@unique([airportId, code])
  @@map("tenant_group")
}

// ============================================
// TENANT SCORE (Risk & Performance)
// ============================================

model TenantScore {
  id                     String       @id @default(uuid())
  tenantId               String       @map("tenant_id")
  scorePeriod            DateTime     @map("score_period") @db.Date
  paymentScore           Int          @map("payment_score")
  declarationScore       Int          @map("declaration_score")
  complianceScore        Int          @map("compliance_score")
  revenuePerformance     Int          @map("revenue_performance")
  overallScore           Int          @map("overall_score")
  riskCategory           RiskCategory @map("risk_category")
  latePaymentCount       Int          @default(0) @map("late_payment_count")
  missedDeclarationCount Int          @default(0) @map("missed_declaration_count")
  totalRevenueDeclared   Decimal?     @map("total_revenue_declared") @db.Decimal(15, 2)
  calculatedAt           DateTime     @default(now()) @map("calculated_at")
  createdAt              DateTime     @default(now()) @map("created_at")

  tenant                 Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, scorePeriod])
  @@index([tenantId])
  @@index([riskCategory])
  @@map("tenant_score")
}

enum RiskCategory {
  low
  medium
  high
  critical
}

// ============================================
// SERVICE DEFINITION & FORMULA
// ============================================

model ServiceDefinition {
  id                    String              @id @default(uuid())
  airportId             String              @map("airport_id")
  code                  String
  name                  String
  serviceType           ServiceType         @map("service_type")
  formulaId             String              @map("formula_id")
  defaultCurrency       String              @default("TRY") @map("default_currency")
  defaultBillingFreq    BillingFrequency    @map("default_billing_freq")
  taxClass              String?             @map("tax_class")
  status                ServiceStatus       @default(draft)
  version               Int                 @default(1)
  effectiveFrom         DateTime            @map("effective_from") @db.Date
  effectiveTo           DateTime?           @map("effective_to") @db.Date
  publishedAt           DateTime?           @map("published_at")
  // === v2: Service Enhancements ===
  requiresEquipment     Boolean             @default(false) @map("requires_equipment")
  requiresDeclaration   Boolean             @default(false) @map("requires_declaration")
  requiresMeterReading  Boolean             @default(false) @map("requires_meter_reading")
  slaDescription        String?             @map("sla_description")
  slaResponseHours      Int?                @map("sla_response_hours")
  // === end v2 ===
  createdAt             DateTime            @default(now()) @map("created_at")

  formula               Formula             @relation(fields: [formulaId], references: [id])
  contractServices      ContractService[]

  @@map("service_definition")
}

enum ServiceType {
  rent
  revenue_share
  service_charge
  utility
  equipment_rental
  allocation_charge
}

enum ServiceStatus {
  draft
  published
  deprecated
}

enum BillingFrequency {
  monthly
  quarterly
  annually
}

model Formula {
  id              String        @id @default(uuid())
  airportId       String        @map("airport_id")
  code            String
  name            String
  formulaType     FormulaType   @map("formula_type")
  expression      String                    // math.js expression string
  variables       Json                      // required context variables definition
  status          FormulaStatus @default(draft)
  version         Int           @default(1)
  publishedAt     DateTime?     @map("published_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  serviceDefinitions ServiceDefinition[]
  contractServiceOverrides ContractService[] @relation("OverrideFormula")

  @@map("formula")
}

enum FormulaType {
  arithmetic
  conditional
  step_band
  revenue_share
  escalation
  proration
  metered
  allocation
}

enum FormulaStatus {
  draft
  published
  archived
}

// ============================================
// EQUIPMENT & ASSET ENGINE
// ============================================

model Equipment {
  id                      String              @id @default(uuid())
  airportId               String              @map("airport_id")
  areaId                  String?             @map("area_id")
  code                    String                                    // EQP-POS-001
  name                    String
  equipmentType           EquipmentType       @map("equipment_type")
  category                EquipmentCategory
  manufacturer            String?
  modelName               String?             @map("model_name")
  serialNumber            String?             @map("serial_number")
  status                  EquipmentStatus     @default(registered)
  ownership               EquipmentOwnership  @default(airport)
  // Financial tracking
  acquisitionDate         DateTime?           @map("acquisition_date") @db.Date
  acquisitionCost         Decimal?            @map("acquisition_cost") @db.Decimal(15, 2)
  depreciationMethod      DepreciationMethod? @map("depreciation_method")
  usefulLifeMonths        Int?                @map("useful_life_months")
  residualValue           Decimal?            @map("residual_value") @db.Decimal(15, 2)
  currentBookValue        Decimal?            @map("current_book_value") @db.Decimal(15, 2)
  // Rental pricing
  monthlyRentalRate       Decimal?            @map("monthly_rental_rate") @db.Decimal(15, 2)
  rentalCurrency          String?             @default("TRY") @map("rental_currency")
  // Insurance & warranty
  warrantyExpiry          DateTime?           @map("warranty_expiry") @db.Date
  insurancePolicy         String?             @map("insurance_policy")
  insuranceExpiry         DateTime?           @map("insurance_expiry") @db.Date
  // Metering capability
  isMetered               Boolean             @default(false) @map("is_metered")
  meterUnit               String?             @map("meter_unit")
  lastMeterReading        Decimal?            @map("last_meter_reading") @db.Decimal(15, 4)
  lastMeterReadAt         DateTime?           @map("last_meter_read_at")
  // Maintenance
  nextMaintenanceAt       DateTime?           @map("next_maintenance_at") @db.Date
  maintenanceIntervalDays Int?                @map("maintenance_interval_days")
  // Sustainability
  energyRating            String?             @map("energy_rating")
  annualEnergyKwh         Decimal?            @map("annual_energy_kwh") @db.Decimal(12, 2)
  commissionedAt          DateTime?           @map("commissioned_at")
  decommissionedAt        DateTime?           @map("decommissioned_at")
  notes                   String?
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  airport            Airport                  @relation(fields: [airportId], references: [id])
  area               Area?                    @relation(fields: [areaId], references: [id])
  meterReadings      EquipmentMeterReading[]
  contractEquipments ContractEquipment[]
  maintenanceLogs    EquipmentMaintenanceLog[]
  obligations        Obligation[]

  @@unique([airportId, code])
  @@index([areaId])
  @@index([equipmentType])
  @@index([status])
  @@map("equipment")
}

enum EquipmentType {
  pos_terminal
  digital_signage
  kiosk
  utility_meter
  hvac_unit
  security_camera
  wifi_access_point
  vending_machine
  furniture_set
  kitchen_equipment
  other
}

enum EquipmentCategory {
  it_infrastructure
  commercial_fixture
  utility_infrastructure
  security
  furniture
  kitchen
  signage
  other_category
}

enum EquipmentStatus {
  registered
  in_storage
  commissioned
  under_maintenance
  decommissioned
  disposed
}

enum EquipmentOwnership {
  airport
  tenant_owned
  third_party
}

enum DepreciationMethod {
  straight_line
  declining_balance
  no_depreciation
}

// ============================================
// EQUIPMENT METER READING
// ============================================

model EquipmentMeterReading {
  id            String             @id @default(uuid())
  equipmentId   String             @map("equipment_id")
  readingDate   DateTime           @map("reading_date") @db.Date
  readingValue  Decimal            @map("reading_value") @db.Decimal(15, 4)
  previousValue Decimal?           @map("previous_value") @db.Decimal(15, 4)
  consumption   Decimal?           @db.Decimal(15, 4)
  unit          String
  readingType   MeterReadingType   @map("reading_type")
  source        MeterReadingSource @default(manual)
  isValidated   Boolean            @default(false) @map("is_validated")
  validatedBy   String?            @map("validated_by")
  validatedAt   DateTime?          @map("validated_at")
  photoUrl      String?            @map("photo_url")
  notes         String?
  createdAt     DateTime           @default(now()) @map("created_at")

  equipment     Equipment          @relation(fields: [equipmentId], references: [id])

  @@index([equipmentId, readingDate])
  @@map("equipment_meter_reading")
}

enum MeterReadingType {
  periodic
  opening
  closing
  audit
}

enum MeterReadingSource {
  manual
  iot
  tenant_declared
}

// ============================================
// EQUIPMENT MAINTENANCE LOG
// ============================================

model EquipmentMaintenanceLog {
  id              String          @id @default(uuid())
  equipmentId     String          @map("equipment_id")
  maintenanceType MaintenanceType @map("maintenance_type")
  description     String
  performedBy     String          @map("performed_by")
  performedAt     DateTime        @map("performed_at")
  cost            Decimal?        @db.Decimal(15, 2)
  currency        String          @default("TRY")
  nextScheduledAt DateTime?       @map("next_scheduled_at") @db.Date
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")

  equipment       Equipment       @relation(fields: [equipmentId], references: [id])

  @@index([equipmentId])
  @@map("equipment_maintenance_log")
}

enum MaintenanceType {
  preventive
  corrective
  inspection
  calibration
}

// ============================================
// CONTRACT EQUIPMENT (Junction)
// ============================================

model ContractEquipment {
  id            String    @id @default(uuid())
  contractId    String    @map("contract_id")
  equipmentId   String    @map("equipment_id")
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  monthlyRate   Decimal?  @map("monthly_rate") @db.Decimal(15, 2)
  rateCurrency  String    @default("TRY") @map("rate_currency")
  includeInBundle Boolean @default(false) @map("include_in_bundle")
  isActive      Boolean   @default(true) @map("is_active")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  equipment     Equipment @relation(fields: [equipmentId], references: [id])

  @@unique([contractId, equipmentId])
  @@index([equipmentId])
  @@map("contract_equipment")
}

// ============================================
// AREA OCCUPANCY (Temporal Tracking)
// ============================================

model AreaOccupancy {
  id            String          @id @default(uuid())
  areaId        String          @map("area_id")
  tenantId      String?         @map("tenant_id")
  contractId    String?         @map("contract_id")
  occupancyType OccupancyType   @map("occupancy_type")
  status        OccupancyStatus @default(planned)
  occupiedFrom  DateTime        @map("occupied_from") @db.Date
  occupiedTo    DateTime?       @map("occupied_to") @db.Date
  occupiedM2    Decimal?        @map("occupied_m2") @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  area          Area            @relation(fields: [areaId], references: [id])
  tenant        Tenant?         @relation(fields: [tenantId], references: [id])
  contract      Contract?       @relation(fields: [contractId], references: [id])

  @@index([areaId, occupiedFrom])
  @@index([tenantId])
  @@map("area_occupancy")
}

enum OccupancyType {
  exclusive
  shared
  temporary
  storage_use
}

enum OccupancyStatus {
  planned
  occupied
  vacated
  under_renovation
}

// ============================================
// AREA ALLOCATION (Shared Cost Splitting)
// ============================================

model AreaAllocation {
  id               String           @id @default(uuid())
  airportId        String           @map("airport_id")
  areaId           String           @map("area_id")
  allocationMethod AllocationMethod @map("allocation_method")
  periodStart      DateTime         @map("period_start") @db.Date
  periodEnd        DateTime?        @map("period_end") @db.Date
  totalCost        Decimal?         @map("total_cost") @db.Decimal(15, 2)
  currency         String           @default("TRY")
  status           AllocationStatus @default(draft)
  approvedBy       String?          @map("approved_by")
  approvedAt       DateTime?        @map("approved_at")
  version          Int              @default(1)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  area             Area             @relation(fields: [areaId], references: [id])
  shares           AreaAllocationShare[]
  obligations      Obligation[]

  @@index([areaId])
  @@map("area_allocation")
}

model AreaAllocationShare {
  id               String         @id @default(uuid())
  allocationId     String         @map("allocation_id")
  tenantId         String         @map("tenant_id")
  contractId       String?        @map("contract_id")
  shareRatio       Decimal        @map("share_ratio") @db.Decimal(10, 8)
  fixedAmount      Decimal?       @map("fixed_amount") @db.Decimal(15, 2)
  calculatedAmount Decimal?       @map("calculated_amount") @db.Decimal(15, 2)
  createdAt        DateTime       @default(now()) @map("created_at")

  allocation       AreaAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  tenant           Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([allocationId, tenantId])
  @@map("area_allocation_share")
}

enum AllocationMethod {
  proportional_m2
  equal_split
  revenue_weighted
  fixed_amount
  passenger_weighted
}

enum AllocationStatus {
  draft
  approved_alloc
  active_alloc
  archived_alloc
}

// ============================================
// CONTRACT (Commercial Digital Twin)
// ============================================

model Contract {
  id                     String            @id @default(uuid())
  airportId              String            @map("airport_id")
  tenantId               String            @map("tenant_id")
  contractNumber         String            @map("contract_number")
  version                Int               @default(1)
  previousVersionId      String?           @map("previous_version_id")
  status                 ContractStatus    @default(draft)
  effectiveFrom          DateTime          @map("effective_from") @db.Date
  effectiveTo            DateTime          @map("effective_to") @db.Date
  annualMag              Decimal?          @map("annual_mag") @db.Decimal(15, 2)
  magCurrency            String?           @default("TRY") @map("mag_currency")
  billingFrequency       BillingFrequency  @default(monthly) @map("billing_frequency")
  responsibleOwner       String?           @map("responsible_owner")
  escalationRule         Json?             @map("escalation_rule")
  depositAmount          Decimal?          @map("deposit_amount") @db.Decimal(15, 2)
  guaranteeType          GuaranteeType?    @map("guarantee_type")
  guaranteeExpiry        DateTime?         @map("guarantee_expiry") @db.Date
  signedAt               DateTime?         @map("signed_at")
  publishedAt            DateTime?         @map("published_at")
  terminatedAt           DateTime?         @map("terminated_at")
  terminationReason      String?           @map("termination_reason")
  // === v2: Contract Enhancements ===
  contractType           ContractType      @default(standard) @map("contract_type")
  performanceTarget      Decimal?          @map("performance_target") @db.Decimal(15, 2)
  performanceMetric      PerformanceMetric? @map("performance_metric")
  performancePenaltyRate Decimal?          @map("performance_penalty_rate") @db.Decimal(5, 4)
  performanceBonusRate   Decimal?          @map("performance_bonus_rate") @db.Decimal(5, 4)
  insuranceRequired      Boolean           @default(false) @map("insurance_required")
  renewalOption          RenewalOption?    @map("renewal_option")
  renewalNoticeDays      Int?              @map("renewal_notice_days")
  // === end v2 ===
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  airport             Airport            @relation(fields: [airportId], references: [id])
  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  previousVersion     Contract?          @relation("ContractVersions", fields: [previousVersionId], references: [id])
  nextVersions        Contract[]         @relation("ContractVersions")
  contractAreas       ContractArea[]
  contractServices    ContractService[]
  contractEquipments  ContractEquipment[]
  obligations         Obligation[]
  settlementEntries   SettlementEntry[]
  areaOccupancies     AreaOccupancy[]
  creditNotes         CreditNote[]

  @@unique([airportId, contractNumber, version])
  @@index([tenantId])
  @@index([status])
  @@map("contract")
}

enum ContractStatus {
  draft
  in_review
  published
  active
  pending_amendment
  amended
  suspended
  terminated
}

enum ContractType {
  standard
  concession
  license
  management
  temporary
}

enum PerformanceMetric {
  revenue
  pax_spend
  sales_per_m2
  footfall
}

enum RenewalOption {
  no_renewal
  auto_renew
  option_to_renew
  mutual_agreement
}

enum GuaranteeType {
  none
  deposit
  bank_letter
  corporate_guarantee
}

model ContractArea {
  id            String    @id @default(uuid())
  contractId    String    @map("contract_id")
  areaId        String    @map("area_id")
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date

  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  area          Area      @relation(fields: [areaId], references: [id])

  @@unique([contractId, areaId])
  @@map("contract_area")
}

model ContractService {
  id                    String            @id @default(uuid())
  contractId            String            @map("contract_id")
  serviceDefinitionId   String            @map("service_definition_id")
  overrideFormulaId     String?           @map("override_formula_id")
  overrideCurrency      String?           @map("override_currency")
  overrideBillingFreq   BillingFrequency? @map("override_billing_freq")
  customParameters      Json?             @map("custom_parameters")
  isActive              Boolean           @default(true) @map("is_active")

  contract              Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  serviceDefinition     ServiceDefinition @relation(fields: [serviceDefinitionId], references: [id])
  overrideFormula       Formula?          @relation("OverrideFormula", fields: [overrideFormulaId], references: [id])

  @@unique([contractId, serviceDefinitionId])
  @@map("contract_service")
}

// ============================================
// CREDIT NOTE (Adjustment/Credit Workflow)
// ============================================

model CreditNote {
  id                  String           @id @default(uuid())
  airportId           String           @map("airport_id")
  tenantId            String           @map("tenant_id")
  contractId          String           @map("contract_id")
  creditNoteNumber    String           @map("credit_note_number")
  reason              CreditNoteReason
  status              CreditNoteStatus @default(draft)
  amount              Decimal          @db.Decimal(15, 2)
  currency            String           @default("TRY")
  description         String
  relatedObligationId String?          @map("related_obligation_id")
  relatedInvoiceLogId String?          @map("related_invoice_log_id")
  approvedBy          String?          @map("approved_by")
  approvedAt          DateTime?        @map("approved_at")
  issuedAt            DateTime?        @map("issued_at")
  voidedAt            DateTime?        @map("voided_at")
  stripeRefundId      String?          @map("stripe_refund_id")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  tenant              Tenant           @relation(fields: [tenantId], references: [id])
  contract            Contract         @relation(fields: [contractId], references: [id])

  @@unique([airportId, creditNoteNumber])
  @@index([tenantId])
  @@index([contractId])
  @@map("credit_note")
}

enum CreditNoteReason {
  billing_error
  service_interruption
  area_unavailability
  equipment_downtime
  goodwill
  contract_amendment
  dispute_resolution
  other_reason
}

enum CreditNoteStatus {
  draft
  pending_approval
  approved_cn
  issued
  voided
}

// ============================================
// OBLIGATION (Auto-generated on contract publish)
// ============================================

model Obligation {
  id                    String            @id @default(uuid())
  airportId             String            @map("airport_id")
  contractId            String            @map("contract_id")
  contractVersion       Int               @map("contract_version")
  tenantId              String            @map("tenant_id")
  serviceDefinitionId   String?           @map("service_definition_id")
  obligationType        ObligationType    @map("obligation_type")
  chargeType            ChargeType        @map("charge_type")
  periodStart           DateTime          @map("period_start") @db.Date
  periodEnd             DateTime          @map("period_end") @db.Date
  dueDate               DateTime          @map("due_date") @db.Date
  amount                Decimal?          @db.Decimal(15, 2)
  currency              String            @default("TRY")
  status                ObligationStatus  @default(scheduled)
  formulaVersion        Int?              @map("formula_version")
  calculationTrace      Json?             @map("calculation_trace")
  sourceDeclarationId   String?           @map("source_declaration_id")
  parentObligationId    String?           @map("parent_obligation_id")
  billingRunId          String?           @map("billing_run_id")
  invoiceLogId          String?           @map("invoice_log_id")
  invoiceProvider       InvoiceProvider   @default(stripe) @map("invoice_provider")
  externalInvoiceId     String?           @map("external_invoice_id")
  taxRate               Decimal?          @map("tax_rate") @db.Decimal(5, 2)
  disputeStatus         DisputeStatus?    @map("dispute_status")
  lineHash              String?           @map("line_hash")
  // === v2: Obligation Enhancements ===
  equipmentId           String?           @map("equipment_id")
  allocationId          String?           @map("allocation_id")
  creditNoteAdjustment  Decimal?          @map("credit_note_adjustment") @db.Decimal(15, 2)
  // === end v2 ===
  createdAt             DateTime          @default(now()) @map("created_at")
  invoicedAt            DateTime?         @map("invoiced_at")
  settledAt             DateTime?         @map("settled_at")
  skippedAt             DateTime?         @map("skipped_at")
  skippedReason         String?           @map("skipped_reason")

  contract              Contract          @relation(fields: [contractId], references: [id])
  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  sourceDeclaration     Declaration?      @relation(fields: [sourceDeclarationId], references: [id])
  parentObligation      Obligation?       @relation("ObligationAdjustment", fields: [parentObligationId], references: [id])
  childObligations      Obligation[]      @relation("ObligationAdjustment")
  billingRun            BillingRun?       @relation(fields: [billingRunId], references: [id])
  invoiceLog            InvoiceLog?       @relation(fields: [invoiceLogId], references: [id])
  equipment             Equipment?        @relation(fields: [equipmentId], references: [id])
  areaAllocation        AreaAllocation?   @relation(fields: [allocationId], references: [id])

  @@unique([lineHash])
  @@index([contractId])
  @@index([tenantId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([chargeType])
  @@index([dueDate])
  @@index([equipmentId])
  @@index([allocationId])
  @@map("obligation")
}

enum ObligationType {
  rent
  revenue_share
  mag_shortfall
  mag_true_up
  equipment
  allocation
}

enum ChargeType {
  base_rent
  revenue_share
  service_charge
  utility
  mag_settlement
  equipment_rental
  allocation_charge
}

enum ObligationStatus {
  scheduled
  pending_input
  pending_calculation
  ready
  invoiced
  settled
  skipped
  on_hold
  cancelled
}

enum InvoiceProvider {
  stripe
  erp
  mock
}

enum DisputeStatus {
  none
  disputed
  resolved
}

// ============================================
// DECLARATION (Tenant-submitted)
// ============================================

model Declaration {
  id                String            @id @default(uuid())
  airportId         String            @map("airport_id")
  tenantId          String            @map("tenant_id")
  contractId        String            @map("contract_id")
  declarationType   DeclarationType   @map("declaration_type")
  periodStart       DateTime          @map("period_start") @db.Date
  periodEnd         DateTime          @map("period_end") @db.Date
  status            DeclarationStatus @default(draft)
  submittedAt       DateTime?         @map("submitted_at")
  frozenAt          DateTime?         @map("frozen_at")
  frozenToken       String?           @map("frozen_token")
  createdAt         DateTime          @default(now()) @map("created_at")

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  lines             DeclarationLine[]
  attachments       DeclarationAttachment[]
  obligations       Obligation[]

  @@map("declaration")
}

model DeclarationLine {
  id              String      @id @default(uuid())
  declarationId   String      @map("declaration_id")
  category        String?
  grossAmount     Decimal     @map("gross_amount") @db.Decimal(15, 2)
  deductions      Decimal     @default(0) @map("deductions") @db.Decimal(15, 2)
  amount          Decimal     @db.Decimal(15, 2)
  unitOfMeasure   String?     @map("unit_of_measure")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")

  declaration     Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@map("declaration_line")
}

model DeclarationAttachment {
  id              String      @id @default(uuid())
  declarationId   String      @map("declaration_id")
  fileName        String      @map("file_name")
  fileType        String      @map("file_type")
  fileUrl         String      @map("file_url")
  fileSizeBytes   Int?        @map("file_size_bytes")
  uploadedBy      String      @map("uploaded_by")
  createdAt       DateTime    @default(now()) @map("created_at")

  declaration     Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@map("declaration_attachment")
}

enum DeclarationType {
  revenue
  meter_reading
}

enum DeclarationStatus {
  draft
  submitted
  validated
  rejected
  frozen
}

// ============================================
// BILLING RUN (Async, Queue-based)
// ============================================

model BillingRun {
  id                String          @id @default(uuid())
  airportId         String          @map("airport_id")
  runType           BillingRunType  @map("run_type")
  periodStart       DateTime        @map("period_start") @db.Date
  periodEnd         DateTime        @map("period_end") @db.Date
  status            BillingRunStatus @default(initiated)
  filters           Json?
  totalObligations  Int?            @map("total_obligations")
  totalAmount       Decimal?        @map("total_amount") @db.Decimal(15, 2)
  totalInvoices     Int?            @map("total_invoices")
  approvedBy        String?         @map("approved_by")
  approvedAt        DateTime?       @map("approved_at")
  completedAt       DateTime?       @map("completed_at")
  errorLog          Json?           @map("error_log")
  contractSnapshot  Json?           @map("contract_snapshot")
  runMode           BillingRunMode  @default(full) @map("run_mode")
  previousRunId     String?         @map("previous_run_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  airport           Airport         @relation(fields: [airportId], references: [id])
  previousRun       BillingRun?     @relation("BillingRunChain", fields: [previousRunId], references: [id])
  nextRuns          BillingRun[]    @relation("BillingRunChain")
  obligations       Obligation[]
  invoiceLogs       InvoiceLog[]

  @@map("billing_run")
}

enum BillingRunType {
  scheduled
  manual
  selective
  settlement
}

enum BillingRunMode {
  full
  delta
}

enum BillingRunStatus {
  initiated
  scoping
  calculating
  draft_ready
  approved
  rejected
  invoicing
  completed
  partial
  cancelled
}

// ============================================
// INVOICE LOG (Stripe mirror)
// ============================================

model InvoiceLog {
  id                    String        @id @default(uuid())
  airportId             String        @map("airport_id")
  billingRunId          String        @map("billing_run_id")
  tenantId              String        @map("tenant_id")
  chargeType            ChargeType    @map("charge_type")
  stripeInvoiceId       String        @unique @map("stripe_invoice_id")
  stripeInvoiceNumber   String?       @map("stripe_invoice_number")
  stripeHostedUrl       String?       @map("stripe_hosted_url")
  stripePdfUrl          String?       @map("stripe_pdf_url")
  status                InvoiceStatus
  amountTotal           Decimal       @map("amount_total") @db.Decimal(15, 2)
  currency              String        @default("TRY")
  dueDate               DateTime?     @map("due_date") @db.Date
  paidAt                DateTime?     @map("paid_at")
  voidedAt              DateTime?     @map("voided_at")
  idempotencyKey        String        @unique @map("idempotency_key")
  metadata              Json?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  billingRun            BillingRun    @relation(fields: [billingRunId], references: [id])
  tenant                Tenant        @relation(fields: [tenantId], references: [id])
  obligations           Obligation[]
  settlementEntries     SettlementEntry[]

  @@index([stripeInvoiceId])
  @@index([tenantId])
  @@index([status])
  @@map("invoice_log")
}

enum InvoiceStatus {
  created
  finalized
  sent
  paid
  past_due
  voided
  uncollectible
}

// ============================================
// SETTLEMENT
// ============================================

model SettlementEntry {
  id                    String          @id @default(uuid())
  airportId             String          @map("airport_id")
  contractId            String          @map("contract_id")
  tenantId              String          @map("tenant_id")
  periodStart           DateTime        @map("period_start") @db.Date
  periodEnd             DateTime        @map("period_end") @db.Date
  settlementType        SettlementType  @map("settlement_type")
  revenueShareAmount    Decimal         @map("revenue_share_amount") @db.Decimal(15, 2)
  magAmount             Decimal         @map("mag_amount") @db.Decimal(15, 2)
  higherOfResult        Decimal         @map("higher_of_result") @db.Decimal(15, 2)
  shortfall             Decimal         @default(0) @db.Decimal(15, 2)
  surplus               Decimal         @default(0) @db.Decimal(15, 2)
  trueUpAmount          Decimal         @default(0) @map("true_up_amount") @db.Decimal(15, 2)
  invoiceLogId          String?         @map("invoice_log_id")
  createdAt             DateTime        @default(now()) @map("created_at")

  contract              Contract        @relation(fields: [contractId], references: [id])
  invoiceLog            InvoiceLog?     @relation(fields: [invoiceLogId], references: [id])

  @@map("settlement_entry")
}

enum SettlementType {
  monthly_mag
  year_end_true_up
}

// ============================================
// BILLING POLICY
// ============================================

model BillingPolicy {
  id                      String        @id @default(uuid())
  airportId               String        @map("airport_id")
  version                 Int           @default(1)
  status                  PolicyStatus  @default(draft)
  cutOffDay               Int           @map("cut_off_day")
  issueDay                Int           @map("issue_day")
  dueDateDays             Int           @default(30) @map("due_date_days")
  leadDays                Int           @default(5) @map("lead_days")
  gracePeriodDays         Int           @default(0) @map("grace_period_days")
  declarationReminderDays Int           @default(3) @map("declaration_reminder_days")
  fiscalYearStartMonth    Int           @default(1) @map("fiscal_year_start_month")
  effectiveFrom           DateTime      @map("effective_from") @db.Date
  approvedBy              String?       @map("approved_by")
  approvedAt              DateTime?     @map("approved_at")
  createdAt               DateTime      @default(now()) @map("created_at")

  airport                 Airport       @relation(fields: [airportId], references: [id])

  @@map("billing_policy")
}

enum PolicyStatus {
  draft
  approved
  active
  archived
}

// ============================================
// NOTIFICATION
// ============================================

model Notification {
  id            String             @id @default(uuid())
  airportId     String             @map("airport_id")
  tenantId      String?            @map("tenant_id")
  userId        String?            @map("user_id")
  type          NotificationType
  channel       NotificationChannel
  title         String
  body          String
  metadata      Json?
  isRead        Boolean            @default(false) @map("is_read")
  readAt        DateTime?          @map("read_at")
  sentAt        DateTime?          @map("sent_at")
  failedAt      DateTime?          @map("failed_at")
  retryCount    Int                @default(0) @map("retry_count")
  createdAt     DateTime           @default(now()) @map("created_at")

  tenant        Tenant?            @relation(fields: [tenantId], references: [id])
  user          User?              @relation(fields: [userId], references: [id])

  @@index([tenantId, isRead])
  @@index([userId, isRead])
  @@map("notification")
}

enum NotificationType {
  cutoff_approaching
  declaration_missing
  invoice_created
  payment_received
  payment_failed
  invoice_overdue
  billing_run_completed
  contract_expiring
  mag_shortfall
  equipment_maintenance_due
  tenant_risk_category_changed
  insurance_expiring
  credit_note_issued
}

enum NotificationChannel {
  email
  in_app
  both
}

// ============================================
// USER (Admin + Tenant)
// ============================================

model User {
  id            String    @id @default(uuid())
  airportId     String?   @map("airport_id")
  tenantId      String?   @map("tenant_id")
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  role          UserRole
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  notifications Notification[]

  @@index([role])
  @@map("user")
}

enum UserRole {
  super_admin
  airport_admin
  commercial_manager
  finance
  auditor
  tenant_admin
  tenant_user
}

// ============================================
// WEBHOOK EVENT LOG
// ============================================

model WebhookEventLog {
  id              String    @id @default(uuid())
  stripeEventId   String    @unique @map("stripe_event_id")
  eventType       String    @map("event_type")
  payload         Json
  processed       Boolean   @default(false)
  processedAt     DateTime? @map("processed_at")
  errorMessage    String?   @map("error_message")
  retryCount      Int       @default(0) @map("retry_count")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([processed])
  @@map("webhook_event_log")
}

// ============================================
// AUDIT LOG (Immutable, append-only)
// ============================================

model AuditLog {
  id            String    @id @default(uuid())
  airportId     String    @map("airport_id")
  entityType    String    @map("entity_type")
  entityId      String    @map("entity_id")
  action        String
  actor         String
  previousState Json?     @map("previous_state")
  newState      Json?     @map("new_state")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

// ============================================
// EXCHANGE RATE (Multi-Currency)
// ============================================

model ExchangeRate {
  id              String    @id @default(uuid())
  airportId       String    @map("airport_id")
  fromCurrency    String    @map("from_currency")
  toCurrency      String    @map("to_currency")
  rate            Decimal   @db.Decimal(19, 8)
  effectiveDate   DateTime  @map("effective_date") @db.Date
  source          String
  notes           String?
  createdBy       String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([fromCurrency, toCurrency, effectiveDate, source])
  @@index([fromCurrency, toCurrency, effectiveDate])
  @@map("exchange_rate")
}
