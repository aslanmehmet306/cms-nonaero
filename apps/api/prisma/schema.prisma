// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AIRPORT & AREA
// ============================================

model Airport {
  id              String   @id @default(uuid())
  code            String   @unique           // ADB
  name            String                     // Izmir Adnan Menderes
  countryCode     String   @map("country_code")
  defaultCurrency String   @default("TRY") @map("default_currency")
  timezone        String   @default("Europe/Istanbul")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  areas           Area[]
  tenants         Tenant[]
  contracts       Contract[]
  billingRuns     BillingRun[]
  billingPolicies BillingPolicy[]

  @@map("airport")
}

model Area {
  id            String   @id @default(uuid())
  airportId     String   @map("airport_id")
  parentAreaId  String?  @map("parent_area_id")
  code          String                       // DOM-G-R-001
  name          String
  areaType      AreaType @map("area_type")   // terminal, floor, zone, unit
  areaM2        Decimal? @map("area_m2") @db.Decimal(10, 2)
  isLeasable    Boolean  @default(false) @map("is_leasable")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  airport       Airport  @relation(fields: [airportId], references: [id])
  parent        Area?    @relation("AreaHierarchy", fields: [parentAreaId], references: [id])
  children      Area[]   @relation("AreaHierarchy")
  contractAreas ContractArea[]

  @@unique([airportId, code])
  @@index([parentAreaId])
  @@map("area")
}

enum AreaType {
  terminal
  floor
  zone
  unit
}

// ============================================
// TENANT
// ============================================

model Tenant {
  id                String       @id @default(uuid())
  airportId         String       @map("airport_id")
  code              String                    // TNT-001
  name              String
  taxId             String?      @map("tax_id")
  email             String?
  phone             String?
  address           String?
  stripeCustomerId  String?      @map("stripe_customer_id")
  status            TenantStatus @default(active)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  airport           Airport      @relation(fields: [airportId], references: [id])
  contracts         Contract[]
  declarations      Declaration[]
  obligations       Obligation[]
  invoiceLogs       InvoiceLog[]
  notifications     Notification[]

  @@unique([airportId, code])
  @@map("tenant")
}

enum TenantStatus {
  active
  suspended
  deactivated
}

// ============================================
// SERVICE DEFINITION & FORMULA
// ============================================

model ServiceDefinition {
  id                    String              @id @default(uuid())
  airportId             String              @map("airport_id")
  code                  String
  name                  String
  serviceType           ServiceType         @map("service_type")
  formulaId             String              @map("formula_id")
  defaultCurrency       String              @default("TRY") @map("default_currency")
  defaultBillingFreq    BillingFrequency    @map("default_billing_freq")
  taxClass              String?             @map("tax_class")
  status                ServiceStatus       @default(draft)
  version               Int                 @default(1)
  effectiveFrom         DateTime            @map("effective_from") @db.Date
  effectiveTo           DateTime?           @map("effective_to") @db.Date
  publishedAt           DateTime?           @map("published_at")
  createdAt             DateTime            @default(now()) @map("created_at")

  formula               Formula             @relation(fields: [formulaId], references: [id])
  contractServices      ContractService[]

  @@map("service_definition")
}

enum ServiceType {
  rent
  revenue_share
  service_charge
  utility
}

enum ServiceStatus {
  draft
  published
  deprecated
}

enum BillingFrequency {
  monthly
  quarterly
  annually
}

model Formula {
  id              String        @id @default(uuid())
  airportId       String        @map("airport_id")
  code            String
  name            String
  formulaType     FormulaType   @map("formula_type")
  expression      String                    // math.js expression string
  variables       Json                      // required context variables definition
  status          FormulaStatus @default(draft)
  version         Int           @default(1)
  publishedAt     DateTime?     @map("published_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  serviceDefinitions ServiceDefinition[]
  contractServiceOverrides ContractService[] @relation("OverrideFormula")

  @@map("formula")
}

enum FormulaType {
  arithmetic
  conditional
  step_band
  revenue_share
  escalation
  proration
}

enum FormulaStatus {
  draft
  published
  archived
}

// ============================================
// CONTRACT (Commercial Digital Twin)
// ============================================

model Contract {
  id                  String          @id @default(uuid())
  airportId           String          @map("airport_id")
  tenantId            String          @map("tenant_id")
  contractNumber      String          @map("contract_number")
  version             Int             @default(1)
  previousVersionId   String?         @map("previous_version_id")
  status              ContractStatus  @default(draft)
  effectiveFrom       DateTime        @map("effective_from") @db.Date
  effectiveTo         DateTime        @map("effective_to") @db.Date
  annualMag           Decimal?        @map("annual_mag") @db.Decimal(15, 2)
  magCurrency         String?         @default("TRY") @map("mag_currency")
  billingFrequency    BillingFrequency @default(monthly) @map("billing_frequency")
  responsibleOwner    String?         @map("responsible_owner")
  escalationRule      Json?           @map("escalation_rule")
  depositAmount       Decimal?        @map("deposit_amount") @db.Decimal(15, 2)
  guaranteeType       GuaranteeType?  @map("guarantee_type")
  guaranteeExpiry     DateTime?       @map("guarantee_expiry") @db.Date
  signedAt            DateTime?       @map("signed_at")
  publishedAt         DateTime?       @map("published_at")
  terminatedAt        DateTime?       @map("terminated_at")
  terminationReason   String?         @map("termination_reason")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  airport             Airport         @relation(fields: [airportId], references: [id])
  tenant              Tenant          @relation(fields: [tenantId], references: [id])
  previousVersion     Contract?       @relation("ContractVersions", fields: [previousVersionId], references: [id])
  nextVersions        Contract[]      @relation("ContractVersions")
  contractAreas       ContractArea[]
  contractServices    ContractService[]
  obligations         Obligation[]
  settlementEntries   SettlementEntry[]

  @@unique([airportId, contractNumber, version])
  @@index([tenantId])
  @@index([status])
  @@map("contract")
}

enum ContractStatus {
  draft
  in_review
  published
  active
  pending_amendment
  amended
  suspended
  terminated
}

enum GuaranteeType {
  none
  deposit
  bank_letter
  corporate_guarantee
}

model ContractArea {
  id            String    @id @default(uuid())
  contractId    String    @map("contract_id")
  areaId        String    @map("area_id")
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date

  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  area          Area      @relation(fields: [areaId], references: [id])

  @@unique([contractId, areaId])
  @@map("contract_area")
}

model ContractService {
  id                    String            @id @default(uuid())
  contractId            String            @map("contract_id")
  serviceDefinitionId   String            @map("service_definition_id")
  overrideFormulaId     String?           @map("override_formula_id")
  overrideCurrency      String?           @map("override_currency")
  overrideBillingFreq   BillingFrequency? @map("override_billing_freq")
  customParameters      Json?             @map("custom_parameters")
  isActive              Boolean           @default(true) @map("is_active")

  contract              Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  serviceDefinition     ServiceDefinition @relation(fields: [serviceDefinitionId], references: [id])
  overrideFormula       Formula?          @relation("OverrideFormula", fields: [overrideFormulaId], references: [id])

  @@unique([contractId, serviceDefinitionId])
  @@map("contract_service")
}

// ============================================
// OBLIGATION (Auto-generated on contract publish)
// ============================================

model Obligation {
  id                    String            @id @default(uuid())
  airportId             String            @map("airport_id")
  contractId            String            @map("contract_id")
  contractVersion       Int               @map("contract_version")
  tenantId              String            @map("tenant_id")
  serviceDefinitionId   String?           @map("service_definition_id")
  obligationType        ObligationType    @map("obligation_type")
  chargeType            ChargeType        @map("charge_type")
  periodStart           DateTime          @map("period_start") @db.Date
  periodEnd             DateTime          @map("period_end") @db.Date
  dueDate               DateTime          @map("due_date") @db.Date
  amount                Decimal?          @db.Decimal(15, 2)
  currency              String            @default("TRY")
  status                ObligationStatus  @default(scheduled)
  formulaVersion        Int?              @map("formula_version")
  calculationTrace      Json?             @map("calculation_trace")
  sourceDeclarationId   String?           @map("source_declaration_id")
  parentObligationId    String?           @map("parent_obligation_id")
  billingRunId          String?           @map("billing_run_id")
  invoiceLogId          String?           @map("invoice_log_id")
  invoiceProvider       InvoiceProvider   @default(stripe) @map("invoice_provider")
  externalInvoiceId     String?           @map("external_invoice_id")
  taxRate               Decimal?          @map("tax_rate") @db.Decimal(5, 2)
  disputeStatus         DisputeStatus?    @map("dispute_status")
  lineHash              String?           @map("line_hash")
  createdAt             DateTime          @default(now()) @map("created_at")
  invoicedAt            DateTime?         @map("invoiced_at")
  settledAt             DateTime?         @map("settled_at")
  skippedAt             DateTime?         @map("skipped_at")
  skippedReason         String?           @map("skipped_reason")

  contract              Contract          @relation(fields: [contractId], references: [id])
  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  sourceDeclaration     Declaration?      @relation(fields: [sourceDeclarationId], references: [id])
  parentObligation      Obligation?       @relation("ObligationAdjustment", fields: [parentObligationId], references: [id])
  childObligations      Obligation[]      @relation("ObligationAdjustment")
  billingRun            BillingRun?       @relation(fields: [billingRunId], references: [id])
  invoiceLog            InvoiceLog?       @relation(fields: [invoiceLogId], references: [id])

  @@unique([lineHash])
  @@index([contractId])
  @@index([tenantId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([chargeType])
  @@index([dueDate])
  @@map("obligation")
}

enum ObligationType {
  rent
  revenue_share
  mag_shortfall
  mag_true_up
}

enum ChargeType {
  base_rent
  revenue_share
  service_charge
  utility
  mag_settlement
}

enum ObligationStatus {
  scheduled
  pending_input
  pending_calculation
  ready
  invoiced
  settled
  skipped
  on_hold
  cancelled
}

enum InvoiceProvider {
  stripe
  erp
  mock
}

enum DisputeStatus {
  none
  disputed
  resolved
}

// ============================================
// DECLARATION (Tenant-submitted)
// ============================================

model Declaration {
  id                String            @id @default(uuid())
  airportId         String            @map("airport_id")
  tenantId          String            @map("tenant_id")
  contractId        String            @map("contract_id")
  declarationType   DeclarationType   @map("declaration_type")
  periodStart       DateTime          @map("period_start") @db.Date
  periodEnd         DateTime          @map("period_end") @db.Date
  status            DeclarationStatus @default(draft)
  submittedAt       DateTime?         @map("submitted_at")
  frozenAt          DateTime?         @map("frozen_at")
  frozenToken       String?           @map("frozen_token")
  createdAt         DateTime          @default(now()) @map("created_at")

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  lines             DeclarationLine[]
  attachments       DeclarationAttachment[]
  obligations       Obligation[]

  @@map("declaration")
}

model DeclarationLine {
  id              String      @id @default(uuid())
  declarationId   String      @map("declaration_id")
  category        String?
  grossAmount     Decimal     @map("gross_amount") @db.Decimal(15, 2)
  deductions      Decimal     @default(0) @map("deductions") @db.Decimal(15, 2)
  amount          Decimal     @db.Decimal(15, 2)
  unitOfMeasure   String?     @map("unit_of_measure")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")

  declaration     Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@map("declaration_line")
}

model DeclarationAttachment {
  id              String      @id @default(uuid())
  declarationId   String      @map("declaration_id")
  fileName        String      @map("file_name")
  fileType        String      @map("file_type")
  fileUrl         String      @map("file_url")
  fileSizeBytes   Int?        @map("file_size_bytes")
  uploadedBy      String      @map("uploaded_by")
  createdAt       DateTime    @default(now()) @map("created_at")

  declaration     Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@map("declaration_attachment")
}

enum DeclarationType {
  revenue
  meter_reading
}

enum DeclarationStatus {
  draft
  submitted
  validated
  rejected
  frozen
}

// ============================================
// BILLING RUN (Async, Queue-based)
// ============================================

model BillingRun {
  id                String          @id @default(uuid())
  airportId         String          @map("airport_id")
  runType           BillingRunType  @map("run_type")
  periodStart       DateTime        @map("period_start") @db.Date
  periodEnd         DateTime        @map("period_end") @db.Date
  status            BillingRunStatus @default(initiated)
  filters           Json?
  totalObligations  Int?            @map("total_obligations")
  totalAmount       Decimal?        @map("total_amount") @db.Decimal(15, 2)
  totalInvoices     Int?            @map("total_invoices")
  approvedBy        String?         @map("approved_by")
  approvedAt        DateTime?       @map("approved_at")
  completedAt       DateTime?       @map("completed_at")
  errorLog          Json?           @map("error_log")
  contractSnapshot  Json?           @map("contract_snapshot")
  runMode           BillingRunMode  @default(full) @map("run_mode")
  previousRunId     String?         @map("previous_run_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  airport           Airport         @relation(fields: [airportId], references: [id])
  previousRun       BillingRun?     @relation("BillingRunChain", fields: [previousRunId], references: [id])
  nextRuns          BillingRun[]    @relation("BillingRunChain")
  obligations       Obligation[]
  invoiceLogs       InvoiceLog[]

  @@map("billing_run")
}

enum BillingRunType {
  scheduled
  manual
  selective
  settlement
}

enum BillingRunMode {
  full
  delta
}

enum BillingRunStatus {
  initiated
  scoping
  calculating
  draft_ready
  approved
  rejected
  invoicing
  completed
  partial
  cancelled
}

// ============================================
// INVOICE LOG (Stripe mirror)
// ============================================

model InvoiceLog {
  id                    String        @id @default(uuid())
  airportId             String        @map("airport_id")
  billingRunId          String        @map("billing_run_id")
  tenantId              String        @map("tenant_id")
  chargeType            ChargeType    @map("charge_type")
  stripeInvoiceId       String        @unique @map("stripe_invoice_id")
  stripeInvoiceNumber   String?       @map("stripe_invoice_number")
  stripeHostedUrl       String?       @map("stripe_hosted_url")
  stripePdfUrl          String?       @map("stripe_pdf_url")
  status                InvoiceStatus
  amountTotal           Decimal       @map("amount_total") @db.Decimal(15, 2)
  currency              String        @default("TRY")
  dueDate               DateTime?     @map("due_date") @db.Date
  paidAt                DateTime?     @map("paid_at")
  voidedAt              DateTime?     @map("voided_at")
  idempotencyKey        String        @unique @map("idempotency_key")
  metadata              Json?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  billingRun            BillingRun    @relation(fields: [billingRunId], references: [id])
  tenant                Tenant        @relation(fields: [tenantId], references: [id])
  obligations           Obligation[]
  settlementEntries     SettlementEntry[]

  @@index([stripeInvoiceId])
  @@index([tenantId])
  @@index([status])
  @@map("invoice_log")
}

enum InvoiceStatus {
  created
  finalized
  sent
  paid
  past_due
  voided
  uncollectible
}

// ============================================
// SETTLEMENT
// ============================================

model SettlementEntry {
  id                    String          @id @default(uuid())
  airportId             String          @map("airport_id")
  contractId            String          @map("contract_id")
  tenantId              String          @map("tenant_id")
  periodStart           DateTime        @map("period_start") @db.Date
  periodEnd             DateTime        @map("period_end") @db.Date
  settlementType        SettlementType  @map("settlement_type")
  revenueShareAmount    Decimal         @map("revenue_share_amount") @db.Decimal(15, 2)
  magAmount             Decimal         @map("mag_amount") @db.Decimal(15, 2)
  higherOfResult        Decimal         @map("higher_of_result") @db.Decimal(15, 2)
  shortfall             Decimal         @default(0) @db.Decimal(15, 2)
  surplus               Decimal         @default(0) @db.Decimal(15, 2)
  trueUpAmount          Decimal         @default(0) @map("true_up_amount") @db.Decimal(15, 2)
  invoiceLogId          String?         @map("invoice_log_id")
  createdAt             DateTime        @default(now()) @map("created_at")

  contract              Contract        @relation(fields: [contractId], references: [id])
  invoiceLog            InvoiceLog?     @relation(fields: [invoiceLogId], references: [id])

  @@map("settlement_entry")
}

enum SettlementType {
  monthly_mag
  year_end_true_up
}

// ============================================
// BILLING POLICY
// ============================================

model BillingPolicy {
  id                      String        @id @default(uuid())
  airportId               String        @map("airport_id")
  version                 Int           @default(1)
  status                  PolicyStatus  @default(draft)
  cutOffDay               Int           @map("cut_off_day")
  issueDay                Int           @map("issue_day")
  dueDateDays             Int           @default(30) @map("due_date_days")
  leadDays                Int           @default(5) @map("lead_days")
  gracePeriodDays         Int           @default(0) @map("grace_period_days")
  declarationReminderDays Int           @default(3) @map("declaration_reminder_days")
  fiscalYearStartMonth    Int           @default(1) @map("fiscal_year_start_month")
  effectiveFrom           DateTime      @map("effective_from") @db.Date
  approvedBy              String?       @map("approved_by")
  approvedAt              DateTime?     @map("approved_at")
  createdAt               DateTime      @default(now()) @map("created_at")

  airport                 Airport       @relation(fields: [airportId], references: [id])

  @@map("billing_policy")
}

enum PolicyStatus {
  draft
  approved
  active
  archived
}

// ============================================
// NOTIFICATION
// ============================================

model Notification {
  id            String             @id @default(uuid())
  airportId     String             @map("airport_id")
  tenantId      String?            @map("tenant_id")
  userId        String?            @map("user_id")
  type          NotificationType
  channel       NotificationChannel
  title         String
  body          String
  metadata      Json?
  isRead        Boolean            @default(false) @map("is_read")
  readAt        DateTime?          @map("read_at")
  sentAt        DateTime?          @map("sent_at")
  failedAt      DateTime?          @map("failed_at")
  retryCount    Int                @default(0) @map("retry_count")
  createdAt     DateTime           @default(now()) @map("created_at")

  tenant        Tenant?            @relation(fields: [tenantId], references: [id])
  user          User?              @relation(fields: [userId], references: [id])

  @@index([tenantId, isRead])
  @@index([userId, isRead])
  @@map("notification")
}

enum NotificationType {
  cutoff_approaching
  declaration_missing
  invoice_created
  payment_received
  payment_failed
  invoice_overdue
  billing_run_completed
  contract_expiring
  mag_shortfall
}

enum NotificationChannel {
  email
  in_app
  both
}

// ============================================
// USER (Admin + Tenant)
// ============================================

model User {
  id            String    @id @default(uuid())
  airportId     String?   @map("airport_id")
  tenantId      String?   @map("tenant_id")
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  role          UserRole
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  notifications Notification[]

  @@index([role])
  @@map("user")
}

enum UserRole {
  super_admin
  airport_admin
  commercial_manager
  finance
  auditor
  tenant_admin
  tenant_user
}

// ============================================
// WEBHOOK EVENT LOG
// ============================================

model WebhookEventLog {
  id              String    @id @default(uuid())
  stripeEventId   String    @unique @map("stripe_event_id")
  eventType       String    @map("event_type")
  payload         Json
  processed       Boolean   @default(false)
  processedAt     DateTime? @map("processed_at")
  errorMessage    String?   @map("error_message")
  retryCount      Int       @default(0) @map("retry_count")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([processed])
  @@map("webhook_event_log")
}

// ============================================
// AUDIT LOG (Immutable, append-only)
// ============================================

model AuditLog {
  id            String    @id @default(uuid())
  airportId     String    @map("airport_id")
  entityType    String    @map("entity_type")
  entityId      String    @map("entity_id")
  action        String
  actor         String
  previousState Json?     @map("previous_state")
  newState      Json?     @map("new_state")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}
