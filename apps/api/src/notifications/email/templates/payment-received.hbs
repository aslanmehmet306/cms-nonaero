<h2 style="color: #333; margin-top: 0;">Odeme Alindi - {{invoiceNumber}}</h2>

<p>Sayin <strong>{{tenantName}}</strong>,</p>

<p>Odemeniz basariyla alindi.</p>

<table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
  <tr style="background: #f8f9fa;">
    <td style="padding: 8px; border: 1px solid #dee2e6;"><strong>Fatura No</strong></td>
    <td style="padding: 8px; border: 1px solid #dee2e6;">{{invoiceNumber}}</td>
  </tr>
  <tr>
    <td style="padding: 8px; border: 1px solid #dee2e6;"><strong>Tutar</strong></td>
    <td style="padding: 8px; border: 1px solid #dee2e6;">{{currency}} {{amount}}</td>
  </tr>
  <tr style="background: #f8f9fa;">
    <td style="padding: 8px; border: 1px solid #dee2e6;"><strong>Odeme Tarihi</strong></td>
    <td style="padding: 8px; border: 1px solid #dee2e6;">{{paidDate}}</td>
  </tr>
</table>

<div style="background: #d4edda; border-left: 4px solid #28a745; padding: 12px; margin: 16px 0;">
  <p style="margin: 0;">Odemeniz icin tesekkur ederiz.</p>
</div>

<p>Saygilarimizla,<br>Havalimani Ticari Gelir Yonetimi</p>
